rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to validate translation data
    function isValidTranslation() {
      return request.resource.data.keys().hasAll([
        'sourceText', 'translatedText', 'sourceLanguage', 'targetLanguage', 'createdAt'
      ]) &&
      request.resource.data.sourceText is string &&
      request.resource.data.translatedText is string &&
      request.resource.data.sourceText.size() <= 5000 &&
      request.resource.data.translatedText.size() <= 10000;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      // Translations subcollection
      match /translations/{translationId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTranslation();
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Favorites subcollection
      match /favorites/{favoriteId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTranslation();
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
